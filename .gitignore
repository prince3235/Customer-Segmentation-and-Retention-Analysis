# ╔══════════════════════════════════════╗
# ║  Customer Segmentation .gitignore   ║
# ╚══════════════════════════════════════╝

# ── Data (large files & sensitive) ────
data/
*.csv
*.xlsx
*.parquet

# ── ML Model Artifacts ────────────────
reports/churn_xgb_model.pkl
reports/pipeline.log

# ── Python ────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── Virtual Environment ───────────────
venv/
env/
.env
.venv/

# ── Jupyter Notebooks ─────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── IDE & OS ──────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# ── Streamlit Cache ───────────────────
.streamlit/

# ── Test & Coverage ───────────────────
.pytest_cache/
htmlcov/
.coverage
*.cover